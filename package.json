    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/material-nextjs": "^9.1.1",
    "@mui/system": "^9.1.1",
    "@mui/x-data-grid": "^9.5.0",
    "@mui/x-date-pickers": "^9.5.0",
    "@reduxjs/toolkit": "^2.12.0",
    "dayjs": "^1.11.21",
    "next": "16.2.9",
    "pluralize": "^8.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0"
